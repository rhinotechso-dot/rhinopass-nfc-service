{
  "name": "rhinopass-nfc-service",
  "version": "0.1.0",
  "description": "Rhinopass NFC bridge desktop app for linking badges and reader status",
  "author": "Rhinopass",
  "private": true,
  "main": "dist/electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev:bridge": "tsx src/index.ts",
    "dev:app": "npm run build && electron dist/electron/main.js",
    "prebuild": "node scripts/generate-icon.js",
    "build": "tsc && node scripts/copy-assets.js",
    "start": "electron dist/electron/main.js",
    "start:bridge": "node dist/index.js",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "electron-store": "^9.0.0",
    "ndef": "^0.2.0",
    "nfc-pcsc": "^0.8.1",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.12",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.rhinopass.nfcbridge",
    "productName": "Rhinopass NFC Bridge",
    "icon": "build/icon.ico",
    "copyright": "© 2026 Rhinopass",
    "win": {
      "publisherName": "Rhinopass",
      "target": [
        "msi",
        "nsis"
      ]
    },
    "msi": {
      "icon": "build/icon.ico"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      "docs/INSTALLATION.txt"
    ],
    "directories": {
      "output": "release"
    }
  }
}
